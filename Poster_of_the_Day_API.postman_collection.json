{
	"info": {
		"name": "Poster of the Day API",
		"description": "Complete API collection for Poster of the Day — Laravel 12 + Sanctum Auth",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8000/api" },
		{ "key": "token", "value": "" }
	],
	"auth": {
		"type": "bearer",
		"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/register",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}"
						}
					},
					"response": [
						{
							"name": "201 Success",
							"status": "Created",
							"code": 201,
							"body": "{\n  \"user\": {\n    \"id\": 1,\n    \"name\": \"Admin User\",\n    \"email\": \"admin@example.com\",\n    \"created_at\": \"2026-04-01T10:00:00.000000Z\"\n  },\n  \"token\": \"1|abc123def456...\",\n  \"permissions\": []\n}"
						},
						{
							"name": "422 Validation Error",
							"status": "Unprocessable Entity",
							"code": 422,
							"body": "{\n  \"message\": \"The email has already been taken.\",\n  \"errors\": {\n    \"email\": [\"The email has already been taken.\"]\n  }\n}"
						}
					]
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json.token) { pm.collectionVariables.set('token', json.token); }"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/login",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
						}
					},
					"response": [
						{
							"name": "200 Success",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"user\": {\n    \"id\": 1,\n    \"name\": \"Admin User\",\n    \"email\": \"admin@example.com\",\n    \"role\": { \"id\": 1, \"name\": \"Super Admin\", \"slug\": \"super_admin\" }\n  },\n  \"token\": \"2|xyz789...\",\n  \"permissions\": [\"dashboard.view\", \"users.view\", \"roles.view\"]\n}"
						},
						{
							"name": "401 Invalid Credentials",
							"status": "Unauthorized",
							"code": 401,
							"body": "{\n  \"message\": \"Invalid credentials\"\n}"
						}
					]
				},
				{
					"name": "Get Authenticated User",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/user",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						]
					},
					"response": [
						{
							"name": "200 Success",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"user\": {\n    \"id\": 1,\n    \"name\": \"Admin User\",\n    \"email\": \"admin@example.com\",\n    \"role\": { \"id\": 1, \"name\": \"Super Admin\", \"slug\": \"super_admin\" }\n  },\n  \"permissions\": [\"dashboard.view\", \"users.view\"]\n}"
						}
					]
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/logout",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						]
					},
					"response": [
						{
							"name": "200 Success",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"message\": \"Logged out successfully\"\n}"
						}
					]
				}
			]
		},
